# ===== СЕКРЕТЫ И КОНФИГУРАЦИЯ =====
# Файл с токенами и паролями - НИКОГДА не коммитим
.env
.env.local
.env.*.local

# ===== PYTHON =====
# Кэш и скомпилированные файлы
__pycache__/
*.py[cod]
*$py.class
*.so

# Виртуальное окружение (библиотеки)
venv/
ENV/
env/
.venv/

# Установленные пакеты
*.egg-info/
*.egg

# ===== ДАННЫЕ (JSON файлы с реальными данными) =====
# Эти файлы генерируются в процессе работы, их не нужно хранить в Git
data/*.json
data/*.log
data/sessions.json

# НО! Оставь шаблоны файлов (если нужны)
# !data/users.json.template

# ===== ЛОГИ =====
*.log
logs/

# ===== ВРЕМЕННЫЕ ФАЙЛЫ =====
*.tmp
*.temp
*~

# ===== IDE И РЕДАКТОРЫ =====
.vscode/
.idea/
*.swp
*.swo

# ===== ОПЕРАЦИОННАЯ СИСТЕМА =====
